# ============================================================
# Quant Platform — environment template.
# Copy to `.env` and fill in. `.env` is git-ignored; never commit secrets.
# Secrets have NO defaults in code — supply them here (or via Secrets Manager
# in production, per ADR-0010).
# ============================================================

# ---- App ----
APP_ENV=local                      # local | test | staging | production
APP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_JSON=false                 # force-true in staging/production

# ---- Database (PostgreSQL + TimescaleDB, ADR-0002) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=quant
DB_PASSWORD=quant                  # override in any non-local env
DB_NAME=quant_platform
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

# ---- Redis (broker + cache, ADR-0003) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ---- Broker (ADR-0005). Phase 1 default is the fake adapter. ----
BROKER_PROVIDER=fake               # fake | alpaca | ibkr
BROKER_PAPER=true                  # paper only until Phase 16
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_BASE_URL=

# ---- JWT (Phase 5). Signing key MUST be supplied in any non-local env. ----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
# JWT_SIGNING_KEY=

# ---- Risk (ADR-0006). Enforce pre-trade by default. ----
RISK_ENFORCE_PRE_TRADE=true
RISK_MAX_GROSS_EXPOSURE_PCT=100.0
RISK_MAX_SINGLE_POSITION_PCT=10.0
